   "source": [
    "# Audit: node24-ci-guard product\n",
    "Analyzes file tree, template imports, and self-containedness."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import json, os\n",
    "from pathlib import Path\n",
    "\n",
    "ROOT = Path('/kaggle/input/node24-ci-guard')\n",
    "files = sorted(p.relative_to(ROOT).as_posix() for p in ROOT.rglob('*') if p.is_file())\n",
    "print('FILES', len(files))\n",
    "for f in files:\n",
    "    print(f)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import re\n",
    "issues = []\n",
    "for p in ROOT.rglob('*.ts'):\n",
    "    text = p.read_text(errors='ignore')\n",
    "    for m in re.finditer(r'path\.join\([^)]*\)', text):\n",
    "        issues.append((str(p.relative_to(ROOT)), m.group(0)))\n",
    "    for m in re.finditer(r'fs\.copy|copyFileSync|readFileSync\(', text):\n",
    "        issues.append((str(p.relative_to(ROOT)), m.group(0)))\n",
    "for item in issues:\n",
    "    print(item[0], '=>', item[1])"
   ]
  }
 ],
